1<%- include('partials/header', { title: 'Register' }) %>

<div class="flex items-center justify-center">
  <div class="w-full max-w-md">
    <form id="register-form" class="bg-white shadow-lg rounded px-12 pt-6 pb-8 mb-4">
      <div class="text-gray-800 text-2xl flex justify-center border-b-2 py-2 mb-4">Crear Cuenta</div>
      <div class="mb-4">
        <label class="block text-gray-700 text-sm font-normal mb-2" for="username"> Usuario </label>
        <input
          class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline"
          name="username"
          id="username"
          type="text"
          required
          placeholder="Username"
        />
      </div>
      <div class="mb-6">
        <label class="block text-gray-700 text-sm font-normal mb-2" for="password"> Contraseña </label>
        <input
          class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 mb-3 leading-tight focus:outline-none focus:shadow-outline"
          type="password"
          placeholder="Password"
          name="password"
          id="password"
          required
        />
      </div>
      <div id="error-message" class="text-red-500 text-xs italic mb-4 hidden"></div>
      <div class="flex items-center justify-between">
        <button
          class="px-4 py-2 rounded text-white inline-block shadow-lg bg-green-500 hover:bg-green-600 focus:bg-green-700"
          type="submit"
        >
          Register
        </button>
        <a class="inline-block align-baseline font-normal text-sm text-green-500 hover:text-green-800" href="/login">
          ¿Ya tienes cuenta? Inicia sesión
        </a>
      </div>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById("register-form");
  const errorMessage = document.getElementById("error-message");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorMessage.classList.add("hidden");

    const username = form.username.value;
    const password = form.password.value;

    try {
      const res = await fetch("/api/auth/register", {
        method: "POST",
        body: JSON.stringify({ username, password }),
        headers: { "Content-Type": "application/json" },
      });

      const data = await res.json();

      if (res.ok) {
        // Redirect to login page after successful registration
        window.location.assign("/login");
      } else {
        errorMessage.textContent = data.error || "Error al registrarse.";
        errorMessage.classList.remove("hidden");
      }
    } catch (err) {
      errorMessage.textContent = "Error de red. Inténtalo de nuevo.";
      errorMessage.classList.remove("hidden");
    }
  });
</script>

<%- include('partials/footer') %>
