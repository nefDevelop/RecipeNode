<%- include('partials/header', { title: 'Planificación', user: user }) %>

<style>
  #calendar {
    --fc-button-bg-color: #10b981;
    --fc-button-border-color: #10b981;
    --fc-button-hover-bg-color: #059669;
    --fc-button-hover-border-color: #059669;
    --fc-button-active-bg-color: #047857;
    --fc-button-active-border-color: #047857;
  }
</style>
<!-- FullCalendar CSS -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" rel="stylesheet" />

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user }) %>

    <main class="w-full md:w-3/4">
      <h1 class="text-3xl font-bold mb-6">Planificación de Comidas</h1>
      <div id="calendar" class="bg-white p-4 rounded-lg shadow"></div>
    </main>
  </div>
</div>

<!-- Modal para asignar comida -->
<div id="meal-modal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
  <div class="relative p-5 border w-full max-w-md shadow-lg rounded-md bg-white">
    <div class="mt-3 text-center">
      <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">Asignar Comida</h3>
      <p class="text-sm text-gray-500" id="modal-date"></p>
      <div class="mt-4">
        <label for="recipe-select" class="block text-sm font-medium text-gray-700 text-left">Selecciona una receta:</label>
        <select
          id="recipe-select"
          class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md"
        >
          <option value="">-- Sin Asignar --</option>
          <% recipeTitles.forEach(function(title) { %>
          <option value="<%= title %>"><%= title %></option>
          <% }); %>
        </select>
      </div>
      <div class="mt-4 grid grid-cols-3 gap-2">
        <button
          data-meal="breakfast"
          class="assign-btn px-4 py-2 bg-yellow-500 text-white text-base font-medium rounded-md w-full shadow-sm hover:bg-yellow-600 focus:outline-none focus:ring-2 focus:ring-yellow-300"
        >
          Desayuno
        </button>
        <button
          data-meal="lunch"
          class="assign-btn px-4 py-2 bg-green-500 text-white text-base font-medium rounded-md w-full shadow-sm hover:bg-green-600 focus:outline-none focus:ring-2 focus:ring-green-300"
        >
          Almuerzo
        </button>
        <button
          data-meal="dinner"
          class="assign-btn px-4 py-2 bg-red-500 text-white text-base font-medium rounded-md w-full shadow-sm hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-300"
        >
          Cena
        </button>
      </div>
      <div class="items-center px-4 py-3 mt-4 border-t">
        <button
          id="clear-day-btn"
          class="px-4 py-2 bg-gray-500 text-white text-base font-medium rounded-md w-full shadow-sm hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-gray-300 mb-2"
        >
          Limpiar Día
        </button>
        <button
          id="close-modal-btn"
          class="px-4 py-2 bg-white text-gray-700 border border-gray-300 text-base font-medium rounded-md w-full shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-200"
        >
          Cerrar
        </button>
      </div>
    </div>
  </div>
</div>

<!-- FullCalendar JS -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/es.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const calendarEl = document.getElementById("calendar");
    const modal = document.getElementById("meal-modal");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const recipeSelect = document.getElementById("recipe-select");
    const modalDateEl = document.getElementById("modal-date");
    const clearDayBtn = document.getElementById("clear-day-btn");
    let selectedDateStr = "";

    const calendar = new FullCalendar.Calendar(calendarEl, {
      initialView: "dayGridMonth",
      locale: "es",
      fixedWeekCount: false,
      headerToolbar: {
        left: "prev,next",
        center: "title",
        right: "dayGridMonth,dayGridWeek",
      },
      height: "auto", // Ajusta la altura para que no se estire innecesariamente
      dayMaxEventRows: 3, // Limita el número de filas de eventos por día
      events: "/api/planning",
      eventContent: function (arg) {
        let mealType = arg.event.extendedProps.meal_type;
        let mealInitial = "";
        let mealColor = "bg-gray-400";

        if (mealType === "breakfast") {
          mealInitial = "D";
          mealColor = "bg-yellow-500";
        } else if (mealType === "lunch") {
          mealInitial = "A";
          mealColor = "bg-green-500";
        } else if (mealType === "dinner") {
          mealInitial = "C";
          mealColor = "bg-red-500";
        }

        let eventHtml = `
          <div class="fc-event-main-frame">
            <div class="fc-event-title-container">
              <div class="fc-event-title fc-sticky"><span class="inline-block text-xs font-bold text-white ${mealColor} rounded-sm px-1 mr-1">${mealInitial}</span>${arg.event.title}</div>
            </div>
          </div>`;

        return { html: eventHtml };
      },
      dateClick: function (info) {
        selectedDateStr = info.dateStr;
        modalDateEl.textContent = new Date(info.dateStr + "T00:00:00").toLocaleDateString("es-ES", {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        recipeSelect.value = "";
        modal.classList.remove("hidden");
      },
      eventClick: function (info) {
        selectedDateStr = info.event.startStr.split("T")[0];
        modalDateEl.textContent = info.event.start.toLocaleDateString("es-ES", {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        recipeSelect.value = info.event.title;
        modal.classList.remove("hidden");
      },
    });

    calendar.render();

    closeModalBtn.addEventListener("click", () => {
      modal.classList.add("hidden");
    });

    document.querySelectorAll(".assign-btn").forEach((button) => {
      button.addEventListener("click", async () => {
        const mealType = button.dataset.meal;
        const recipeName = recipeSelect.value;

        await fetch("/api/planning", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            date: selectedDateStr,
            meal_type: mealType,
            recipe_name: recipeName, // Empty string will clear the assignment
          }),
        });

        calendar.refetchEvents();
        modal.classList.add("hidden");
      });
    });

    clearDayBtn.addEventListener("click", async () => {
      const mealTypes = ["breakfast", "lunch", "dinner"];
      const promises = mealTypes.map((mealType) => {
        return fetch("/api/planning", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            date: selectedDateStr,
            meal_type: mealType,
            recipe_name: "", // Empty string triggers deletion
          }),
        });
      });

      await Promise.all(promises);

      calendar.refetchEvents();
      modal.classList.add("hidden");
    });

    // Close modal on outside click
    window.addEventListener("click", (event) => {
      if (event.target === modal) {
        modal.classList.add("hidden");
      }
    });
  });
</script>

<%- include('partials/footer') %>
