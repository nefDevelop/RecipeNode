<%- include('partials/header', { title: 'Planificación', user: user }) %>

<style>
  /* --- Estilos Personalizados para FullCalendar --- */

  /* Colores de los botones de navegación (prev, next, month, week) */
  #calendar {
    --fc-button-bg-color: #22c55e; /* green-500 */
    --fc-button-border-color: #22c55e; /* green-500 */
    --fc-button-hover-bg-color: #16a34a; /* green-600 */
    --fc-button-hover-border-color: #16a34a; /* green-600 */
    --fc-button-active-bg-color: #15803d; /* green-700 */
    --fc-button-active-border-color: #15803d; /* green-700 */
  }

  /* Tamaño de los botones (más pequeños) */
  .fc-button {
    padding: 0.4em 0.4em !important; /* Pequeño padding, forzado */
    font-size: 0.9em !important; /* Pequeño tamaño de fuente, forzado */

  }

  /* Tamaño del texto del mes/semana */
  .fc-toolbar-title {
    padding: 5px 25px;
    /* Usamos clamp() para un tamaño de fuente adaptable con límites. */
    /* clamp(MÍNIMO, PREFERIDO, MÁXIMO) */
    font-size: clamp(1.7rem, 3vw, 3.5rem) !important;
    /* font-weight: bold; */
  }

  /* Cabecera de días de la semana (L, M, X...) - MODO CLARO */
  .fc-col-header-cell {
    background-color: #ffffff; /* white */
  }
  .fc-col-header-cell-cushion {
    color: #4b5563; /* gray-600 */
    text-decoration: none;
    padding: 8px 4px;
  }

  /* Dark mode styles for FullCalendar */
  .dark #calendar {
    --fc-border-color: #4a5568; /* gray-700 */
  }
  .dark .fc-col-header-cell {
    background-color: #374151; /* gray-700 */
  }
  /* Cabecera de días de la semana - MODO OSCURO */
  .dark .fc-col-header-cell-cushion {
    /* Nombres de los días de la semana */
    color: #9ca3af; /* gray-400 */
    text-decoration: none;
  }
  .dark .fc-daygrid-day-number {
    /* Números de los días */
    color: #cbd5e0; /* gray-400 */
  }
</style>
<!-- FullCalendar CSS -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" rel="stylesheet" />

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user }) %>

    <main class="w-full md:w-3/4">
      <h1 class="text-3xl font-bold mb-6">Planificación de Comidas</h1>
      <div id="calendar" class="bg-white dark:bg-gray-800 p-4 rounded-lg shadow"></div>
    </main>
  </div>
</div>

<!-- Modal de Planificación -->
<div id="planningModal" class="fixed inset-0 bg-gray-600 bg-opacity-75 hidden z-50 flex items-center justify-center p-4">
  <div class="relative p-5 border w-full max-w-md shadow-lg rounded-md bg-white dark:bg-gray-800">
    <button id="close-modal-btn" class="absolute top-2 right-2 text-gray-500 hover:text-gray-800 dark:hover:text-gray-200">&times;</button>
    <h2 id="modalTitle" class="text-lg leading-6 font-medium text-gray-900 dark:text-gray-100">Planificar Comidas</h2>
    <form id="planningForm" class="mt-4 space-y-4">
      <input type="hidden" id="planningDate" name="date" />

      <div>
        <label for="breakfastSelect" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Desayuno:</label>
        <select id="breakfastSelect" name="breakfast" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
          <option value="">-- Sin desayuno --</option>
          <% recipeTitles.forEach(title => { %>
          <option value="<%= title %>"><%= title %></option>
          <% }); %>
        </select>
      </div>

      <div>
        <label for="lunchSelect" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Almuerzo:</label>
        <select id="lunchSelect" name="lunch" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
          <option value="">-- Sin almuerzo --</option>
          <% recipeTitles.forEach(title => { %>
          <option value="<%= title %>"><%= title %></option>
          <% }); %>
        </select>
      </div>

      <div>
        <label for="dinnerSelect" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Cena:</label>
        <select id="dinnerSelect" name="dinner" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
          <option value="">-- Sin cena --</option>
          <% recipeTitles.forEach(title => { %>
          <option value="<%= title %>"><%= title %></option>
          <% }); %>
        </select>
      </div>

      <div class="mt-6 flex flex-col sm:flex-row-reverse gap-3">
        <button type="submit" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-green-600 text-base font-medium text-white hover:bg-green-700 focus:outline-none sm:w-auto sm:text-sm">Aceptar</button>
        <button type="button" id="clearDayButton" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 focus:outline-none sm:mt-0 sm:w-auto sm:text-sm">Limpiar Día</button>
      </div>
    </form>
    </div>
  </div>
</div>

<!-- FullCalendar JS -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/es.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const calendarEl = document.getElementById("calendar");
    const modal = document.getElementById("planningModal");
    const form = document.getElementById("planningForm");
    const planningDateInput = document.getElementById("planningDate");
    const modalTitle = document.getElementById("modalTitle");
    const closeModalBtn = document.getElementById("close-modal-btn");
    const clearDayButton = document.getElementById("clearDayButton");
    let selectedDateStr = "";

    const calendar = new FullCalendar.Calendar(calendarEl, {
      initialView: "dayGridMonth",
      locale: "es",
      fixedWeekCount: false,
      headerToolbar: {
        left: "prev,next",
        center: "title",
        right: "dayGridMonth,dayGridWeek",
      },
      height: "auto", // Ajusta la altura para que no se estire innecesariamente
      dayMaxEventRows: 3, // Limita el número de filas de eventos por día
      events: "/api/planning",
      eventContent: function (arg) {
        let mealType = arg.event.extendedProps.meal_type;
        let mealInitial = "";
        let mealColor = "bg-gray-400";

        if (mealType === "breakfast") {
          mealInitial = "D";
          mealColor = "bg-yellow-500";
        } else if (mealType === "lunch") {
          mealInitial = "A";
          mealColor = "bg-green-500";
        } else if (mealType === "dinner") {
          mealInitial = "C";
          mealColor = "bg-red-500";
        }

        let eventHtml = `
          <div class="fc-event-main-frame">
            <div class="fc-event-title-container">
              <div class="fc-event-title fc-sticky"><span class="inline-block text-xs font-bold text-white ${mealColor} rounded-sm px-1 mr-1">${mealInitial}</span>${arg.event.title}</div>
            </div>
          </div>`;

        return { html: eventHtml };
      },
      dateClick: function (info) {
        const isAuthenticated = <%= isAuthenticated %>;
        if (!isAuthenticated) {
          // alert("Debes iniciar sesión para planificar comidas.");
          return;
        }

        selectedDateStr = info.dateStr;
        const dayEvents = calendar.getEvents().filter((e) => e.startStr.startsWith(info.dateStr));
        const meals = {};
        dayEvents.forEach((event) => {
          meals[event.extendedProps.meal_type] = event.title;
        });
        openModal(info.dateStr, meals);
      },
      eventClick: function (info) {
        const isAuthenticated = <%= isAuthenticated %>;
        if (!isAuthenticated) {
          // Para usuarios no logueados, no hacemos nada al hacer clic en un evento.
          return;
        }

        const dateStr = info.event.startStr.split("T")[0];
        const dayEvents = calendar.getEvents().filter((e) => e.startStr.startsWith(dateStr));
        const meals = {};
        dayEvents.forEach((event) => {
          meals[event.extendedProps.meal_type] = event.title;
        });
        openModal(dateStr, meals);
      },
    });

    calendar.render();

    function openModal(date, meals = {}) {
      selectedDateStr = date;
      planningDateInput.value = date;
      modalTitle.textContent = `Planificar para ${new Date(date + "T00:00:00").toLocaleDateString("es-ES", { dateStyle: "long" })}`;

      document.getElementById("breakfastSelect").value = meals.breakfast || "";
      document.getElementById("lunchSelect").value = meals.lunch || "";
      document.getElementById("dinnerSelect").value = meals.dinner || "";

      modal.classList.remove("hidden");
    }

    function closeModal() {
      modal.classList.add("hidden");
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const date = planningDateInput.value;
      const meals = {
        breakfast: document.getElementById("breakfastSelect").value,
        lunch: document.getElementById("lunchSelect").value,
        dinner: document.getElementById("dinnerSelect").value,
      };

      try {
        const response = await fetch("/api/planning/day", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ date, meals }),
        });
        if (!response.ok) throw new Error("Error al guardar la planificación.");
      } catch (error) {
        console.error(error);
        alert("Hubo un error al guardar. Inténtalo de nuevo.");
      } finally {
        calendar.refetchEvents();
        closeModal();
      }
    });

    clearDayButton.addEventListener("click", async () => {
      if (!confirm(`¿Estás seguro de que quieres borrar todas las comidas del día ${selectedDateStr}?`)) {
        return;
      }
      try {
        const res = await fetch(`/api/planning/day`, {
          method: "DELETE",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ date: selectedDateStr }),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || "La respuesta del servidor no fue OK");
        }
      } catch (error) {
        console.error("Error al limpiar el día:", error);
        alert(`Ocurrió un error al limpiar el día: ${error.message}`);
      } finally {
        calendar.refetchEvents();
        closeModal();
      }
    });

    closeModalBtn.addEventListener("click", closeModal);
    // Close modal on outside click
    window.addEventListener("click", (event) => {
      if (event.target === modal) {
        closeModal();
      }
    });
  });
</script>

<%- include('partials/footer') %>
