<%- include('partials/header', { title: 'Lista de la Compra' }) %>

<div class="bg-white p-6 rounded-lg shadow">
  <h1 class="text-2xl font-bold mb-6 border-b pb-4">Generar Lista de la Compra</h1>

  <!-- Controles de Fecha -->
  <div class="flex flex-wrap items-end gap-4 mb-6">
    <div>
      <label for="startDate" class="block text-sm font-medium text-gray-700">Fecha de Inicio</label>
      <input
        type="date"
        id="startDate"
        name="startDate"
        class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
      />
    </div>
    <div>
      <label for="endDate" class="block text-sm font-medium text-gray-700">Fecha de Fin</label>
      <input
        type="date"
        id="endDate"
        name="endDate"
        class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
      />
    </div>
    <button
      id="generate-list-btn"
      class="px-6 py-2 rounded text-white inline-block shadow-lg bg-green-500 hover:bg-green-600 focus:bg-green-700"
    >
      Generar
    </button>
  </div>

  <!-- Área de la Lista -->
  <div id="shopping-list-container">
    <p id="placeholder-text" class="text-gray-500">Selecciona un rango de fechas para generar tu lista de la compra.</p>
    <ul id="shopping-list" class="list-disc pl-5 space-y-2">
      <!-- Los ingredientes se insertarán aquí -->
    </ul>
    <p id="error-message" class="text-red-500 hidden"></p>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const generateBtn = document.getElementById("generate-list-btn");
    const listContainer = document.getElementById("shopping-list");
    const placeholder = document.getElementById("placeholder-text");
    const errorMsg = document.getElementById("error-message");

    generateBtn.addEventListener("click", async () => {
      const startDate = document.getElementById("startDate").value;
      const endDate = document.getElementById("endDate").value;

      if (!startDate || !endDate) {
        alert("Por favor, selecciona una fecha de inicio y de fin.");
        return;
      }

      listContainer.innerHTML = "";
      placeholder.textContent = "Generando lista...";
      errorMsg.classList.add("hidden");

      try {
        const response = await fetch(`/api/shopping-list?startDate=${startDate}&endDate=${endDate}`);
        const ingredients = await response.json();

        placeholder.classList.add("hidden");

        if (ingredients.length === 0) {
          placeholder.textContent = "No hay recetas planificadas para este período.";
          placeholder.classList.remove("hidden");
        } else {
          ingredients.forEach((item) => {
            const li = document.createElement("li");
            li.textContent = item.display;
            listContainer.appendChild(li);
          });
        }
      } catch (err) {
        placeholder.classList.add("hidden");
        errorMsg.textContent = "Error al generar la lista. Por favor, inténtalo de nuevo.";
        errorMsg.classList.remove("hidden");
      }
    });
  });
</script>

<%- include('partials/footer') %>
