<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RecipeNode - <%= title %></title>
    <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.14/index.global.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" rel="stylesheet" />
  </head>
  <body class="bg-gray-100 text-gray-800">
    <nav class="bg-white shadow-md">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center">
            <a href="/" class="font-bold text-xl text-green-600">RecipeNode</a>
            <div class="hidden md:block">
              <div class="ml-10 flex items-baseline space-x-4">
                <a href="/" class="text-gray-700 hover:bg-green-500 hover:text-white px-3 py-2 rounded-md text-sm font-medium">Recetas</a>
                <a href="/planning" class="text-gray-700 hover:bg-green-500 hover:text-white px-3 py-2 rounded-md text-sm font-medium"
                  >Planificación</a
                >
                <a href="/shopping-list" class="text-gray-700 hover:bg-green-500 hover:text-white px-3 py-2 rounded-md text-sm font-medium"
                  >Lista de Compra</a
                >
              </div>
            </div>
          </div>
          <!-- Botón Hamburguesa para móvil -->
          <div class="-mr-2 flex md:hidden">
            <button
              type="button"
              id="mobile-menu-button"
              class="bg-white inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-green-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-800 focus:ring-white"
            >
              <span class="sr-only">Open main menu</span>
              <i class="bi bi-list text-2xl"></i>
            </button>
          </div>
          <div class="hidden md:block">
            <div class="ml-4 flex items-center md:ml-6">
              <% if (user && user.userId) { %>
              <span class="text-gray-600 mr-4">Hola, <%= user.username %></span>
              <a href="/settings" class="text-gray-700 hover:bg-green-500 hover:text-white px-3 py-2 rounded-md text-sm font-medium"
                >Ajustes</a
              >
              <a href="/api/auth/logout" class="bg-red-500 text-white hover:bg-red-600 px-3 py-2 rounded-md text-sm font-medium">Logout</a>
              <% } else { %>
              <a href="/login" class="text-gray-700 hover:bg-gray-200 px-3 py-2 rounded-md text-sm font-medium">Login</a>
              <a href="/register" class="bg-green-500 text-white hover:bg-green-600 ml-2 px-3 py-2 rounded-md text-sm font-medium"
                >Register</a
              >
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <!-- Menú desplegable para móvil -->
      <div class="md:hidden hidden" id="mobile-menu">
        <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
          <a href="/" class="text-gray-700 hover:bg-green-500 hover:text-white block px-3 py-2 rounded-md text-base font-medium">Recetas</a>
          <a href="/planning" class="text-gray-700 hover:bg-green-500 hover:text-white block px-3 py-2 rounded-md text-base font-medium"
            >Planificación</a
          >
          <a
            href="/shopping-list"
            class="text-gray-700 hover:bg-green-500 hover:text-white block px-3 py-2 rounded-md text-base font-medium"
            >Lista de Compra</a
          >
        </div>
        <div class="pt-4 pb-3 border-t border-gray-200">
          <% if (user && user.userId) { %>
          <div class="flex items-center px-5">
            <div class="ml-3">
              <div class="text-base font-medium leading-none text-gray-800"><%= user.username %></div>
            </div>
          </div>
          <div class="mt-3 px-2 space-y-1">
            <a href="/settings" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-white hover:bg-green-500"
              >Ajustes</a
            >
            <a
              href="/api/auth/logout"
              class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-white hover:bg-green-500"
              >Logout</a
            >
          </div>
          <% } %>
        </div>
      </div>
    </nav>
    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8"></main>
  </body>
</html>
