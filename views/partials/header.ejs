<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Carga el plugin de tipografía para la clase 'prose' -->
    <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
    <link rel="stylesheet" href="/css/admonitions.css" />
    <script>
      // Configura Tailwind para usar el modo oscuro basado en clases
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            typography: ({ theme }) => ({
              DEFAULT: {
                css: {
                  "--tw-prose-links": theme("colors.green[600]"),
                  "--tw-prose-headings": theme("colors.gray[900]"),
                  "--tw-prose-bold": theme("colors.gray[900]"),
                  "--tw-prose-bullets": theme("colors.green[500]"),
                  // Ocultar la viñeta (marker) de los `li` que contienen un checkbox.
                  'li:has(input[type="checkbox"])::marker': {
                    content: "none",
                  },
                  // Estilos personalizados para los checkboxes
                  'input[type="checkbox"]': {
                    appearance: "none",
                    width: "1.25em",
                    height: "1.25em",
                    border: `2px solid ${theme("colors.gray.300")}`,
                    borderRadius: theme("borderRadius.md"),
                    display: "inline-block",
                    verticalAlign: "middle",
                    position: "relative",
                    cursor: "pointer",
                    marginRight: "0.5em",
                  },
                  'input[type="checkbox"]:checked': {
                    borderColor: theme("colors.green.500"),
                    backgroundColor: theme("colors.green.500"),
                    backgroundImage: `url("data:image/svg+xml,%3csvg viewBox='0 0 16 16' fill='white' xmlns='http://www.w3.org/2000/svg'%3e%3cpath d='M12.207 4.793a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0l-2-2a1 1 0 011.414-1.414L6.5 9.086l4.293-4.293a1 1 0 011.414 0z'/%3e%3c/svg%3e")`,
                    backgroundSize: "100% 100%",
                    backgroundPosition: "center",
                  },
                  // Estilos para las imágenes dentro del contenido
                  img: {
                    borderRadius: theme("borderRadius.lg"),
                    boxShadow: theme("boxShadow.md"),
                  },
                },
              },
              // Estilos para el modo oscuro (cuando se usa `dark:prose-invert`)
              invert: {
                css: {
                  "--tw-prose-links": theme("colors.green[400]"),
                  "--tw-prose-headings": theme("colors.white"),
                  "--tw-prose-bold": theme("colors.white"),
                  "--tw-prose-bullets": theme("colors.green[400]"),
                  'li:has(input[type="checkbox"])::marker': {
                    content: "none",
                  },
                  // Estilos de checkbox para modo oscuro
                  'input[type="checkbox"]': {
                    borderColor: theme("colors.gray.600"),
                  },
                  'input[type="checkbox"]:checked': {
                    borderColor: theme("colors.green.400"),
                    backgroundColor: theme("colors.green.400"),
                  },
                  img: {
                    borderRadius: theme("borderRadius.lg"),
                    boxShadow: theme("boxShadow.md"),
                  },
                },
              },
            }),
          },
        },
      };
    </script>
    <script>
      // Aplica el tema oscuro/claro al cargar la página para evitar parpadeos (FOUC)
      if (localStorage.theme === "dark" || (!("theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body class="bg-gray-100 dark:bg-gray-900 text-gray-800 dark:text-gray-200 transition-colors duration-300">
    <header class="bg-white dark:bg-gray-800 shadow-md sticky top-0 z-50 h-16 flex items-center">
      <div class="container mx-auto px-4 flex justify-between items-center gap-4">
        <!-- Hamburger -->
        <div class="md:hidden">
          <button id="hamburger-btn" class="text-gray-600 hover:text-green-600 focus:outline-none">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
          </button>
        </div>

        <!-- Logo (visible on mobile) -->
        <a href="/" class="text-2xl font-bold text-green-600 md:hidden">R</a>
        <!-- Logo (visible on desktop) -->
        <a href="/" class="text-2xl font-bold text-green-600 hidden md:block">RecipeNode</a>

        <!-- Search Bar and Filter -->
        <div class="relative flex-grow max-w-xl mx-4">
          <div class="relative flex items-center">
            <input
              type="text"
              id="recipe-search-input"
              placeholder="Buscar recetas..."
              class="w-full p-2 pl-10 rounded-full bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 focus:outline-none focus:ring-2 focus:ring-green-500"
              autocomplete="off"
            />
            <svg
              class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-500 dark:text-gray-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
              ></path>
            </svg>
            <button
              id="filter-toggle-btn"
              class="absolute right-2 top-1/2 transform -translate-y-1/2 p-1 rounded-full hover:bg-gray-200 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-green-500"
              title="Activar filtros"
            >
              <svg
                class="w-5 h-5 text-gray-500 dark:text-gray-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
                ></path>
              </svg>
            </button>
          </div>
          <!-- Search Results Dropdown -->
          <div id="search-results" class="absolute mt-1 w-full bg-white dark:bg-gray-700 rounded-md shadow-lg z-50 hidden"></div>

          <!-- Filter Options (initially hidden) -->
          <div id="filter-options" class="absolute mt-1 w-full bg-white dark:bg-gray-700 rounded-md shadow-lg z-50 hidden p-4 space-y-3 border border-gray-200 dark:border-gray-600">
            <h3 class="font-semibold text-gray-700 dark:text-gray-300">Filtros</h3>
            <!-- Cooking Time Filter -->
            <div>
              <label for="cooking-time-filter" class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >Tiempo de Cocción (minutos)</label
              >
              <input
                type="number"
                id="cooking-time-filter"
                min="1"
                class="mt-1 w-full p-2 rounded-md bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 focus:outline-none focus:ring-2 focus:ring-green-500"
                placeholder="Máx. minutos"
              />
            </div>

            <!-- Ingredients Filter -->
            <div>
              <label for="ingredients-filter" class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >Ingredientes (separados por coma)</label
              >
              <input
                type="text"
                id="ingredients-filter"
                class="mt-1 w-full p-2 rounded-md bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 focus:outline-none focus:ring-2 focus:ring-green-500"
                placeholder="Ej: pollo, arroz"
              />
            </div>

            <!-- Cuisine Type Filter -->
            <div>
              <label for="cuisine-filter" class="block text-sm font-medium text-gray-700 dark:text-gray-300"
                >Tipo de Cocina</label
              >
              <select
                id="cuisine-filter"
                class="mt-1 w-full p-2 rounded-md bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 focus:outline-none focus:ring-2 focus:ring-green-500"
              >
                <option value="">Todos</option>
                <option value="Italiana">Italiana</option>
                <option value="Mexicana">Mexicana</option>
                <option value="Asiática">Asiática</option>
                <option value="Postres">Postres</option>
                <!-- Add more options as needed -->
              </select>
            </div>




          </div>
        </div>

        <!-- Action Buttons -->
        <div class="relative flex items-center">
          <% if (user && user.userId) { %>
          <button
            id="add-recipe-dropdown-btn"
            class="flex items-center justify-center w-10 h-10 bg-green-600 text-white rounded-full hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </button>
          <!-- Dropdown Menu -->
          <div
            id="add-recipe-dropdown"
            class="absolute right-0 top-full mt-2 w-48 bg-white dark:bg-gray-700 rounded-md shadow-lg z-50 hidden"
          >
            <a
              href="#"
              id="show-create-modal-btn"
              class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600"
              >Crear Manualmente</a
            >
            <a
              href="#"
              id="show-scrape-modal-btn-header"
              class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600"
              >Importar desde URL</a
            >
          </div>
          <% } %>
        </div>
      </div>
    </header>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const addRecipeDropdownBtn = document.getElementById("add-recipe-dropdown-btn");
        const addRecipeDropdown = document.getElementById("add-recipe-dropdown");

        // Abrir/cerrar el menú desplegable
        addRecipeDropdownBtn?.addEventListener("click", (e) => {
          e.stopPropagation();
          addRecipeDropdown?.classList.toggle("hidden");
        });

        // Cerrar el menú si se hace clic fuera
        document.addEventListener("click", (e) => {
          if (!addRecipeDropdown?.contains(e.target) && !addRecipeDropdownBtn?.contains(e.target)) {
            addRecipeDropdown?.classList.add("hidden");
          }
        });

        // --- Lógica para abrir el modal unificado desde el header ---
        const createModal = document.getElementById("create-recipe-modal");
        const manualBtn = document.getElementById("show-create-modal-btn");
        const scrapeBtn = document.getElementById("show-scrape-modal-btn-header");

        manualBtn?.addEventListener("click", (e) => {
          e.preventDefault();
          createModal?.classList.remove("hidden");
          document.getElementById("manual-tab")?.click(); // Activa la pestaña manual
        });

        scrapeBtn?.addEventListener("click", (e) => {
          e.preventDefault();
          createModal?.classList.remove("hidden");
          document.getElementById("scrape-tab")?.click(); // Activa la pestaña de importar
        });
      });
    </script>
  </body>
</html>
