<!-- Create Recipe Modal (Global) -->
<div id="create-recipe-modal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
  <div class="relative bg-white dark:bg-gray-800 w-full max-w-lg p-5 border dark:border-gray-700 rounded-md shadow-lg max-h-full overflow-y-auto">
    <div class="flex justify-between items-center pb-3 border-b dark:border-gray-700">
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100">Añadir Receta</p>
      <button id="close-create-modal-btn" class="text-gray-400 hover:text-gray-600">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="create-recipe-container" class="mt-4 mb-6">
      <!-- Tabs -->
      <div class="flex border-b border-gray-200 dark:border-gray-700 mb-4">
        <button id="manual-tab" class="py-2 px-4 font-semibold">Manual</button>
        <button id="scrape-tab" class="py-2 px-4 font-semibold">Importar</button>
      </div>

      <!-- Manual Form -->
      <form id="create-manual-form">
        <div class="mb-4">
          <label for="title" class="block text-sm font-medium text-gray-700">Título</label>
          <input
            type="text"
            name="title"
            id="title"
            required
            class="mt-1 block w-full px-3 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
          />
        </div>
        <div class="mb-4">
          <label for="markdownContent" class="block text-sm font-medium text-gray-700">Contenido (Markdown)</label>
          <textarea
            name="markdownContent"
            id="markdownContent"
            rows="10"
            required
            class="mt-1 block w-full px-3 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full px-4 py-2 rounded text-white inline-block shadow-lg bg-green-500 hover:bg-green-600 focus:bg-green-700"
        >
          Guardar Receta
        </button>
      </form>

      <!-- Scrape Form -->
      <form id="create-scrape-form" class="hidden">
        <div class="mb-4">
          <label for="url" class="block text-sm font-medium text-gray-700">URL de la Receta</label>
          <input
            type="url"
            name="url"
            id="url"
            required
            placeholder="https://ejemplo.com/receta"
            class="mt-1 block w-full px-3 py-2 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
          />
        </div>
        <button
          type="submit"
          class="w-full px-4 py-2 rounded text-white inline-block shadow-lg bg-green-500 hover:bg-green-600 focus:bg-green-700"
        >
          Importar Receta
        </button>
      </form>
      <p id="create-error-message" class="text-red-500 text-xs mt-2 hidden"></p>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script id="recipe-data" type="application/json">
  <%- JSON.stringify({ recipeTitles: recipeTitles || [] }) %>
</script>
<script src="/js/recipe-scaler.js"></script>
<script src="/js/sidebar-search.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // --- Theme Switcher ---
    const themeToggle = document.getElementById("theme-toggle");

    // Sincroniza el toggle con el estado actual al cargar la página
    if (localStorage.theme === "dark" || (!("theme" in localStorage) && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
      if (themeToggle) themeToggle.checked = true;
    }

    if (themeToggle) {
      themeToggle.addEventListener("change", function () {
        if (this.checked) {
          document.documentElement.classList.add("dark");
          localStorage.theme = "dark";
        } else {
          document.documentElement.classList.remove("dark");
          localStorage.theme = "light";
        }
      });
    }

    // --- Sidebar Mobile ---
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const sidebar = document.getElementById('sidebar');
    const sidebarOverlay = document.getElementById('sidebar-overlay');
    const closeSidebarBtn = document.getElementById('close-sidebar-btn');

    const toggleSidebar = () => {
        if (sidebar) {
            sidebar.classList.toggle('-translate-x-full');
            sidebarOverlay.classList.toggle('hidden');
        }
    };

    if (hamburgerBtn) hamburgerBtn.addEventListener('click', toggleSidebar);
    if (sidebarOverlay) sidebarOverlay.addEventListener('click', toggleSidebar);
    if (closeSidebarBtn) closeSidebarBtn.addEventListener('click', toggleSidebar);

    // --- Create Recipe Modal ---
    const createModal = document.getElementById('create-recipe-modal');
    if (createModal) {
        const showCreateModalBtn = document.getElementById('show-create-modal-btn');
        const closeCreateModalBtn = document.getElementById('close-create-modal-btn');

        if (showCreateModalBtn) {
            showCreateModalBtn.addEventListener('click', () => createModal.classList.remove('hidden'));
        }
        if (closeCreateModalBtn) {
            closeCreateModalBtn.addEventListener('click', () => createModal.classList.add('hidden'));
        }
        // Close on outside click
        window.addEventListener('click', (event) => {
            if (event.target === createModal) {
                createModal.classList.add('hidden');
            }
        });

        // --- Create Recipe Form Logic ---
        const manualTab = document.getElementById("manual-tab");
        const scrapeTab = document.getElementById("scrape-tab");
        const manualForm = document.getElementById("create-manual-form");
        const scrapeForm = document.getElementById("create-scrape-form");
        const errorMessage = document.getElementById("create-error-message");

        const switchCreateTab = (mode) => {
          manualForm.classList.toggle("hidden", mode !== "manual");
          scrapeForm.classList.toggle("hidden", mode !== "scrape");
          [manualTab, scrapeTab].forEach((tab) => {
            const isActive = tab.id.startsWith(mode);
            tab.classList.toggle("border-green-600", isActive);
            tab.classList.toggle("text-green-600", isActive);
            tab.classList.toggle("bg-white", isActive);
            tab.classList.toggle("dark:bg-gray-800", isActive);
            tab.classList.toggle("bg-gray-100", !isActive);
            tab.classList.toggle("dark:bg-gray-700", !isActive);
            tab.classList.toggle("text-gray-500", !isActive);
            tab.classList.toggle("dark:text-gray-400", !isActive);
          });
        };

        manualTab.addEventListener("click", () => switchCreateTab("manual"));
        scrapeTab.addEventListener("click", () => switchCreateTab("scrape"));
        // Set initial state
        switchCreateTab("manual");

        const handleFormSubmit = async (url, body) => {
          errorMessage.classList.add("hidden");
          try {
            const res = await fetch(url, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(body),
            });
            const data = await res.json();
            if (res.ok) {
              window.location.reload();
            } else {
              errorMessage.textContent = data.error || "Ocurrió un error.";
              errorMessage.classList.remove("hidden");
            }
          } catch (err) {
            errorMessage.textContent = "Error de red. Inténtalo de nuevo.";
            errorMessage.classList.remove("hidden");
          }
        };

        manualForm.addEventListener("submit", (e) => { e.preventDefault(); handleFormSubmit("/api/recipes", { title: manualForm.title.value, markdownContent: manualForm.markdownContent.value }); });
        scrapeForm.addEventListener("submit", (e) => { e.preventDefault(); handleFormSubmit("/api/recipes/scrape", { url: scrapeForm.url.value }); });
    }
});
</script>

<!-- PWA Service Worker Registration -->
<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/service-worker.js')
        .then(registration => {
          console.log('Service Worker registrado con éxito:', registration);
        })
        .catch(error => {
          console.log('Error al registrar el Service Worker:', error);
        });
    });
  }
</script>

</body>
</html>