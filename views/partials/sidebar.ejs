<aside
  id="sidebar"
  class="fixed top-16 left-0 w-72 h-[calc(100vh-4rem)] bg-white dark:bg-gray-800 p-4 shadow-lg transform -translate-x-full transition-transform duration-300 ease-in-out z-40 md:relative md:translate-x-0 md:top-0 md:w-1/4 md:h-auto md:p-6 md:rounded-lg md:shadow-md"
>
  <!-- Contenido interno de la barra lateral -->
  <div class="h-full overflow-y-auto flex flex-col">
    <div class="flex justify-between items-center mb-4">
      <!-- <h2 class="text-xl font-bold"></h2> -->
      <!-- Close button for mobile -->
      <button id="close-sidebar-btn" class="md:hidden text-gray-500 hover:text-gray-800 text-2xl">&times;</button>
    </div>

    <div class="space-y-2 mb-4 pb-4 border-b border-gray-200 dark:border-gray-600">
      <a href="/" class="flex items-center px-3 py-2 -mx-3 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-md"
        >Recetas</a
      >
      <a
        href="/planning"
        class="flex items-center px-3 py-2 -mx-3 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-md"
        >Planificación</a
      >
      <a
        href="/shopping-list"
        class="flex items-center px-3 py-2 -mx-3 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-md"
        >Lista de la Compra</a
      >
    </div>

    <!-- Most Viewed Recipes -->
    <% if (typeof mostViewed !== 'undefined' && mostViewed.length > 0) { %>
    <div class="mb-4 pb-4 border-b border-gray-200 dark:border-gray-600">
      <h3 class="text-lg font-semibold mb-2">Más Consultadas</h3>
      <ul class="space-y-2">
        <% mostViewed.forEach(recipe => { %>
        <li>
          <a
            href="/?recipe=<%= encodeURIComponent(recipe.name) %>"
            class="flex justify-between items-center text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-md p-2"
          >
            <span class="truncate pr-2"><%= recipe.name %></span>
            <span class="flex-shrink-0 flex items-center text-xs text-gray-500 dark:text-gray-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                <path
                  fill-rule="evenodd"
                  d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.022 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z"
                  clip-rule="evenodd"
                />
              </svg>
              <%= recipe.views %>
            </span>
          </a>
        </li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <div class="space-y-2 mb-4 pb-4 border-b border-gray-200 dark:border-gray-600">
      <% if (user && user.userId) { %>
      <a
        href="/settings"
        class="flex items-center px-3 py-2 -mx-3 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-md"
        >Ajustes</a
      >
      <a
        href="/api/auth/logout"
        class="flex items-center px-3 py-2 -mx-3 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-md"
        >Logout</a
      >
      <% } else { %>
      <a
        href="/login"
        class="flex items-center px-3 py-2 -mx-3 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-md"
        >Login</a
      >
      <a
        href="/register"
        class="flex items-center px-3 py-2 -mx-3 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-md"
        >Registro</a
      >
      <% } %>
    </div>

    <!-- Theme switcher -->
    <div class="mt-auto pt-4 border-t border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Modo Oscuro</span>
        <label for="theme-toggle" class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="theme-toggle" class="sr-only peer" />
          <div
            class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-300 dark:peer-focus:ring-green-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-green-600"
          ></div>
        </label>
      </div>
    </div>
  </div>
</aside>
