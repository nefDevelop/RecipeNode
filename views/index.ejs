<%- include('partials/header', { title: title || 'Recetas', user: user }) %>

<!-- Estilos para el Modo Cocina -->
<link rel="stylesheet" href="/css/kitchen-mode.css" />
<link rel="stylesheet" href="/css/print.css" media="print" />

<!-- Create Recipe Modal -->
<div id="create-recipe-modal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
  <div class="relative bg-white w-full max-w-lg p-5 border rounded-md shadow-lg max-h-full overflow-y-auto">
    <div class="flex justify-between items-center pb-3 border-b">
      <p class="text-2xl font-bold">Añadir Receta</p>
      <button id="close-create-modal-btn" class="text-gray-400 hover:text-gray-600">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="create-recipe-container" class="mt-4 mb-6">
      <!-- Tabs -->
      <div class="flex border-b mb-4">
        <button id="manual-tab" class="py-2 px-4 bg-white text-green-600 border-b-2 border-green-600 font-semibold">Manual</button>
        <button id="scrape-tab" class="py-2 px-4 bg-gray-100 text-gray-500">Importar</button>
      </div>

      <!-- Manual Form -->
      <form id="create-manual-form">
        <div class="mb-4">
          <label for="title" class="block text-sm font-medium text-gray-700">Título</label>
          <input
            type="text"
            name="title"
            id="title"
            required
            class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
          />
        </div>
        <div class="mb-4">
          <label for="markdownContent" class="block text-sm font-medium text-gray-700">Contenido (Markdown)</label>
          <textarea
            name="markdownContent"
            id="markdownContent"
            rows="10"
            required
            class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full px-4 py-2 rounded text-white inline-block shadow-lg bg-green-500 hover:bg-green-600 focus:bg-green-700"
        >
          Guardar Receta
        </button>
      </form>

      <!-- Scrape Form -->
      <form id="create-scrape-form" class="hidden">
        <div class="mb-4">
          <label for="url" class="block text-sm font-medium text-gray-700">URL de la Receta</label>
          <input
            type="url"
            name="url"
            id="url"
            required
            placeholder="https://ejemplo.com/receta"
            class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
          />
        </div>
        <button
          type="submit"
          class="w-full px-4 py-2 rounded text-white inline-block shadow-lg bg-green-500 hover:bg-green-600 focus:bg-green-700"
        >
          Importar Receta
        </button>
      </form>
      <p id="create-error-message" class="text-red-500 text-xs mt-2 hidden"></p>
    </div>
  </div>
</div>

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user }) %>

    <!-- Main Content -->
    <main class="w-full md:w-3/4">
      <div class="bg-white p-6 rounded-lg shadow min-h-[80vh]">
        <% if (content) { %>
        <!-- Contenedor para el Modo Cocina -->
        <div id="recipe-content-wrapper" class="relative">
          <!-- Botones de Acción -->
          <div class="flex flex-wrap justify-end gap-2 mb-4">
            <button
              id="enter-kitchen-mode-btn"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700"
            >
              Modo Cocina
            </button>
            <button
              id="print-recipe-btn"
              class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 -ml-1" viewBox="0 0 20 20" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M5 4v3H4a2 2 0 00-2 2v6a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-1V4a2 2 0 00-2-2H7a2 2 0 00-2 2zm8 0H7v3h6V4zm0 8H7v4h6v-4z"
                  clip-rule="evenodd"
                />
              </svg>
              Imprimir
            </button>
            <button
              id="share-recipe-btn"
              class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 -ml-1" viewBox="0 0 20 20" fill="currentColor">
                <path
                  d="M15 8a3 3 0 10-2.977-2.63l-4.94 2.47a3 3 0 100 4.319l4.94 2.47a3 3 0 10.895-1.789l-4.94-2.47a3.027 3.027 0 000-.74l4.94-2.47C13.456 7.68 14.19 8 15 8z"
                />
              </svg>
              Compartir
            </button>
          </div>

          <!-- Botón para salir (inicialmente oculto por CSS) -->
          <button id="exit-kitchen-mode-btn" title="Salir del Modo Cocina (Esc)">Salir</button>

          <!-- Contenido de la receta -->
          <article class="prose lg:prose-xl max-w-none"><%- content %></article>
        </div>
        <% } else { %>
        <div class="text-center text-gray-500 pt-16">
          <h1 class="text-2xl font-bold">Bienvenido a RecipeNode</h1>
          <p class="mt-2">Selecciona una receta de la lista para verla aquí.</p>
        </div>
        <% } %>
      </div>
    </main>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const createContainer = document.getElementById("create-recipe-container");

    // --- Print and Share Functionality ---
    const printBtn = document.getElementById("print-recipe-btn");
    if (printBtn) {
      printBtn.addEventListener("click", () => {
        window.print();
      });
    }

    const shareBtn = document.getElementById("share-recipe-btn");
    if (shareBtn) {
      shareBtn.addEventListener("click", async () => {
        const recipeTitle = document.querySelector("#recipe-content-wrapper .prose h1")?.textContent || "Receta de RecipeNode";
        const recipeUrl = window.location.href.split("#")[0]; // URL limpia sin hash

        if (navigator.share) {
          // Usa la API Web Share si está disponible (móviles)
          try {
            await navigator.share({
              title: recipeTitle,
              text: `Echa un vistazo a esta receta: ${recipeTitle}`,
              url: recipeUrl,
            });
          } catch (error) {
            console.error("Error al usar Web Share API:", error);
          }
        } else {
          // Fallback para escritorio: copiar al portapapeles
          try {
            await navigator.clipboard.writeText(recipeUrl);
            const originalText = shareBtn.textContent;
            shareBtn.textContent = "¡Enlace Copiado!";
            setTimeout(() => {
              shareBtn.textContent = originalText;
            }, 2000);
          } catch (err) {
            alert("No se pudo copiar el enlace. Cópialo manualmente desde la barra de direcciones.");
          }
        }
      });
    }

    // --- Search Functionality ---
    const searchInput = document.getElementById("recipe-search");
    const recipeList = document.getElementById("recipe-list");
    const recipes = recipeList ? Array.from(recipeList.getElementsByTagName("li")) : [];

    // --- Create Recipe Form ---

    const manualTab = document.getElementById("manual-tab");
    const scrapeTab = document.getElementById("scrape-tab");
    const manualForm = document.getElementById("create-manual-form");
    const scrapeForm = document.getElementById("create-scrape-form");
    const errorMessage = document.getElementById("create-error-message");

    manualTab.addEventListener("click", () => {
      manualForm.classList.remove("hidden");
      scrapeForm.classList.add("hidden");
      manualTab.classList.add("border-green-600", "font-semibold", "bg-white", "text-green-600");
      manualTab.classList.remove("bg-gray-100", "text-gray-500");
      scrapeTab.classList.add("bg-gray-100", "text-gray-500");
      scrapeTab.classList.remove("border-green-600", "font-semibold", "bg-white", "text-green-600");
    });

    scrapeTab.addEventListener("click", () => {
      scrapeForm.classList.remove("hidden");
      manualForm.classList.add("hidden");
      scrapeTab.classList.add("border-green-600", "font-semibold", "bg-white", "text-green-600");
      scrapeTab.classList.remove("bg-gray-100", "text-gray-500");
      manualTab.classList.add("bg-gray-100", "text-gray-500");
      manualTab.classList.remove("border-green-600", "font-semibold", "bg-white", "text-green-600");
    });

    const handleFormSubmit = async (url, body) => {
      errorMessage.classList.add("hidden");
      try {
        const res = await fetch(url, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (res.ok) {
          window.location.reload();
        } else {
          errorMessage.textContent = data.error || "Ocurrió un error.";
          errorMessage.classList.remove("hidden");
        }
      } catch (err) {
        errorMessage.textContent = "Error de red. Inténtalo de nuevo.";
        errorMessage.classList.remove("hidden");
      }
    };

    manualForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const title = manualForm.title.value;
      const markdownContent = manualForm.markdownContent.value;
      handleFormSubmit("/api/recipes", { title, markdownContent });
    });

    scrapeForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const url = scrapeForm.url.value;
      handleFormSubmit("/api/recipes/scrape", { url });
    });
  });
</script>

<!-- Script para el Modo Cocina -->
<script src="/js/kitchen-mode.js"></script>

<%- include('partials/footer') %>
