<%- include('partials/header', { title: title || 'Recetas', user: user }) %>

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user, mostViewed: mostViewed }) %>
    <!-- Main Content -->
    <main class="w-full md:flex-grow flex-1 min-w-0">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow min-h-[80vh]">
        <% if (content) { %>
        <!-- Si se ha seleccionado una receta, se muestra su contenido -->
        <!-- Contenedor para el Modo Cocina -->
        <div id="recipe-content-wrapper" class="relative">
          <!-- Estilos específicos para la vista de receta (Modo Cocina e Impresión) -->
          <link rel="stylesheet" href="/css/kitchen-mode.css" />
          <link rel="stylesheet" href="/css/print.css" media="print" />

          <div class="recipe-view-header">
            <% if (typeof views !== 'undefined' && views > 0) { %>
            <div class="flex items-center text-gray-500 dark:text-gray-400 text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                <path
                  fill-rule="evenodd"
                  d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.022 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z"
                  clip-rule="evenodd"
                />
              </svg>
              <span>Visto <%= views %> veces</span>
            </div>
            <% } else { %>
            <div></div>
            <!-- Div vacío para mantener el espacio cuando no hay vistas -->
            <% } %>

            <!-- Botones de Acción -->
            <div class="flex flex-wrap justify-end gap-2">
              <!-- Modo Cocina -->
              <button
                id="enter-kitchen-mode-btn"
                title="Modo Cocina"
                class="inline-flex items-center justify-center w-10 h-10 border border-transparent rounded-full shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
              >
                <!-- Icono de libro abierto -->
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                  />
                </svg>
              </button>
              <!-- Imprimir -->
              <button
                id="print-recipe-btn"
                class="inline-flex items-center justify-center w-10 h-10 border border-gray-300 dark:border-gray-600 rounded-full shadow-sm text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M5 4v3H4a2 2 0 00-2 2v6a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-1V4a2 2 0 00-2-2H7a2 2 0 00-2 2zm8 0H7v3h6V4zm0 8H7v4h6v-4z"
                    clip-rule="evenodd"
                  />
                </svg>
              </button>
              <!-- Compartir -->
              <button
                id="share-recipe-btn"
                title="Compartir"
                class="inline-flex items-center justify-center w-10 h-10 border border-gray-300 dark:border-gray-600 rounded-full shadow-sm text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    d="M15 8a3 3 0 10-2.977-2.63l-4.94 2.47a3 3 0 100 4.319l4.94 2.47a3 3 0 10.895-1.789l-4.94-2.47a3.027 3.027 0 000-.74l4.94-2.47C13.456 7.68 14.19 8 15 8z"
                  />
                </svg>
              </button>
            </div>
          </div>

          <!-- Contenido de la receta -->
          <div class="recipe-print-content">
             <article class="prose dark:prose-invert lg:prose-xl max-w-none"><%- content %></article>
          </div>
          
        </div>
        <% } else { %>
        <!-- Si estamos en la página principal, mostramos la galería -->
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-6">
          <h1 class="text-3xl font-bold mb-4 sm:mb-0">Todas las Recetas</h1>
          <div class="flex items-center space-x-4">
            <!-- Controles de Ordenación -->
            <div class="flex items-center">
              <label for="sort-by" class="mr-2 text-gray-700 dark:text-gray-300">Ordenar por:</label>
              <select
                id="sort-by"
                class="p-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100"
              >
                <option value="name_asc" <%= sortBy === 'name_asc' ? 'selected' : '' %>>Nombre (A-Z)</option>
                <option value="name_desc" <%= sortBy === 'name_desc' ? 'selected' : '' %>>Nombre (Z-A)</option>
                <option value="date_added_desc" <%= sortBy === 'date_added_desc' ? 'selected' : '' %>>Más Recientes</option>
                <option value="views_desc" <%= sortBy === 'views_desc' ? 'selected' : '' %>>Más Vistas</option>
              </select>
            </div>

            <!-- Controles de Vista -->
            <div class="flex space-x-2">
              <button
                id="grid-view-btn"
                class="p-2 rounded-md border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600"
                title="Vista de Cuadrícula"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM13 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2h-2zM13 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2h-2z"
                  />
                </svg>
              </button>
              <button
                id="list-view-btn"
                class="p-2 rounded-md border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600"
                title="Vista de Lista"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 9a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM9 13a1 1 0 011-1h6a1 1 0 110 2h-6a1 1 0 01-1-1z"
                    clip-rule="evenodd"
                  />
                </svg>
              </button>
            </div>
          </div>
        </div>
        <div id="recipe-gallery" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          <% if (recipes && recipes.length > 0) { %> <% recipes.forEach(recipe => { %>
          <!-- Contenedor relativo para posicionar el botón de borrado -->
          <div
            data-url="/?recipe=<%= encodeURIComponent(recipe.name) %>"
            class="recipe-card relative group bg-gray-50 dark:bg-gray-700 rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 cursor-pointer"
          >
            <% const displayFields = settings.recipe_card_display_fields || {}; %>
            <% if (displayFields.image) { %>
            <div class="image-container relative pb-[75%] bg-green-100">
              <!-- Ratio de aspecto 4:3 -->
              <% if (recipe.image) { %>
              <img
                src="<%- recipe.image %>"
                alt="<%= recipe.name %>"
                class="absolute h-full w-full object-cover"
                onerror="this.style.display='none'; this.parentElement.querySelector('.placeholder').style.display='flex';"
              />
              <div
                class="placeholder absolute h-full w-full bg-green-100 dark:bg-green-900 items-center justify-center"
                style="display: none"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-12 h-12 text-green-300"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                  />
                </svg>
              </div>
              <% } else { %>
              <div class="absolute h-full w-full bg-green-100 dark:bg-green-900 flex items-center justify-center">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-12 h-12 text-green-300"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1"
                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                  />
                </svg>
              </div>
              <% } %>
            </div>
            <% } %>
            <div class="p-4 flex flex-col flex-grow min-w-0">
              <div class="recipe-card-header">
                <% if (displayFields.name) { %>
                <h3
                  class="font-semibold text-lg text-gray-800 dark:text-gray-200 group-hover:text-green-600 truncate"
                  title="<%= recipe.name %>"
                >
                  <%= recipe.name %>
                </h3>
                <% } %> <% if (displayFields.cookingTime && recipe.cooking_time) { %>
                <div class="meta-item cooking-time">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 mr-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span><%= recipe.cooking_time %> min</span>
                </div>
                <% } %>
              </div>

              <% if (displayFields.description && recipe.description) { %>
              <p class="text-sm text-gray-500 dark:text-gray-400 truncate mt-1" title="<%= recipe.description %>">
                <%= recipe.description %>
              </p>
              <% } %>

              <div class="recipe-meta-grid mt-3">
                <% if (displayFields.difficulty && recipe.difficulty) { %>
                <div class="meta-item">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 mr-1"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  <span><%= recipe.difficulty %></span>
                </div>
                <% } %> <% if (displayFields.rating && recipe.rating) { %>
                <div class="meta-item">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path
                      d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                    />
                  </svg>
                  <span><%= recipe.rating %>/5</span>
                </div>
                <% } %>
              </div>

              <% if (displayFields.tags && recipe.tags && recipe.tags.length > 0) { %>
              <div class="mt-auto pt-3">
                <div class="flex flex-wrap gap-1">
                  <% recipe.tags.slice(0, 3).forEach(tag => { %>
                  <span class="tag-pill"><%= tag %></span>
                  <% }) %>
                </div>
              </div>
              <% } %>
            </div>
            <!-- Botón de Borrar (Solo para Admins) -->
            <% if (user && user.role === 'admin') { %>
            <button
              class="delete-recipe-btn absolute top-2 right-2 w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
              data-recipe-name="<%= recipe.name %>"
              title="Eliminar receta"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z"
                  clip-rule="evenodd"
                />
              </svg>
            </button>
            <% } %>
          </div>
          <% }) %> <% } else { %>
          <!-- Mensaje por si algo falla -->
          <div class="text-center text-gray-500 pt-16 col-span-full">
            <h1 class="text-2xl font-bold">Bienvenido a RecipeNode</h1>
            <p class="mt-2">No hay recetas para mostrar. ¡Añade alguna!</p>
          </div>
          <% } %>
        </div>
        <% } %>
      </div>
    </main>

    <!-- Timer Modal/Overlay -->
    <div id="timer-modal" class="fixed inset-0 bg-black bg-opacity-75 flex items-center justify-center z-[1001] hidden">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-xl text-center relative">
        <h2 id="timer-modal-title" class="text-2xl font-bold mb-4">Temporizador</h2>
        <div id="timer-display" class="text-6xl font-mono mb-6">00:00</div>
        <div class="flex justify-center gap-4">
          <button
            id="timer-start-pause-btn"
            class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2"
          >
            Iniciar
          </button>
          <button
            id="timer-reset-btn"
            class="px-6 py-3 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:ring-offset-2"
          >
            Reiniciar
          </button>
          <button
            id="timer-close-btn"
            class="px-6 py-3 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-200 focus:ring-offset-2"
          >
            Cerrar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.recipeCardDisplaySettings = <%- JSON.stringify(settings.recipe_card_display_fields || {}) %>;

  document.addEventListener("DOMContentLoaded", () => {
    // --- Lógica para Borrar Recetas (Admin) ---
    const deleteButtons = document.querySelectorAll(".delete-recipe-btn");
    deleteButtons.forEach((button) => {
      button.addEventListener("click", async (e) => {
        e.preventDefault(); // Evita que se siga el enlace de la tarjeta
        e.stopPropagation(); // Detiene la propagación del evento

        const recipeName = button.dataset.recipeName;
        if (confirm(`¿Estás seguro de que quieres eliminar la receta "${recipeName}"? Esta acción no se puede deshacer.`)) {
          try {
            const response = await fetch("/api/recipes", {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ title: recipeName }),
            });

            const result = await response.json();
            if (!response.ok) {
              throw new Error(result.error || "Error al eliminar la receta.");
            }

            // Eliminar la tarjeta de la receta del DOM
            button.closest(".recipe-card").remove();
            // Opcional: mostrar una notificación de éxito
            alert(result.message);
          } catch (error) {
            alert(`Error: ${error.message}`);
          }
        }
      });
    });

    // --- Print and Share Functionality ---
    const printBtn = document.getElementById("print-recipe-btn");
    if (printBtn) {
      printBtn.addEventListener("click", () => {
        window.print();
      });
    }

    const shareBtn = document.getElementById("share-recipe-btn");
    if (shareBtn) {
      shareBtn.addEventListener("click", async () => {
        const recipeTitle = document.querySelector("#recipe-content-wrapper .prose h1")?.textContent || "Receta de RecipeNode";
        const recipeUrl = window.location.href.split("#")[0]; // URL limpia sin hash

        if (navigator.share) {
          // Usa la API Web Share si está disponible (móviles)
          try {
            await navigator.share({
              title: recipeTitle,
              text: `Echa un vistazo a esta receta: ${recipeTitle}`,
              url: recipeUrl,
            });
          } catch (error) {
            console.error("Error al usar Web Share API:", error);
          }
        } else {
          // Fallback para escritorio: copiar al portapapeles
          try {
            await navigator.clipboard.writeText(recipeUrl);
            const originalText = shareBtn.textContent;
            shareBtn.textContent = "¡Enlace Copiado!";
            setTimeout(() => {
              shareBtn.textContent = originalText;
            }, 2000);
          } catch (err) {
            alert("No se pudo copiar el enlace. Cópialo manualmente desde la barra de direcciones.");
          }
        }
      });
    }

    // --- Ingredient Checkbox Usability ---
    const recipeArticle = document.querySelector(".prose");
    if (recipeArticle) {
      recipeArticle.addEventListener("click", (event) => {
        // Encuentra el elemento de lista (`li`) más cercano al que se hizo clic
        const li = event.target.closest("li");

        // Si el `li` existe y contiene un checkbox...
        if (li && li.querySelector('input[type="checkbox"]')) {
          // ...y el clic no fue directamente en el checkbox (para evitar doble toggle)...
          if (event.target.tagName !== "INPUT") {
            const checkbox = li.querySelector('input[type="checkbox"]');
            checkbox.checked = !checkbox.checked; // ...invierte su estado.
          }
        }
      });
    }

    // --- Recipe Card Click Handler ---
    const recipeCards = document.querySelectorAll(".recipe-card");
    recipeCards.forEach((card) => {
      card.addEventListener("click", (e) => {
        // Evita que el clic en el botón de borrado propague al contenedor
        if (e.target.closest(".delete-recipe-btn")) {
          return;
        }
        const url = card.dataset.url;
        if (url) {
          window.location.href = url;
        }
      });
    });
  });
</script>

<!-- Script para el Modo Cocina -->
<script src="/js/kitchen-mode.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const sortBySelect = document.getElementById("sort-by");
    if (sortBySelect) {
      sortBySelect.addEventListener("change", (event) => {
        const selectedSort = event.target.value;
        const url = new URL(window.location.href);
        url.searchParams.set("sort_by", selectedSort);
        window.location.href = url.toString();
      });
    }

    const recipeGallery = document.getElementById("recipe-gallery");
    const gridViewBtn = document.getElementById("grid-view-btn");
    const listViewBtn = document.getElementById("list-view-btn");

    const savedView = localStorage.getItem("recipeViewType") || "grid"; // Default to grid

    function applyView(viewType) {
      const imageContainers = document.querySelectorAll(".recipe-card .image-container");

      if (recipeGallery) {
        if (viewType === "list") {
          recipeGallery.classList.remove("grid", "grid-cols-1", "sm:grid-cols-2", "lg:grid-cols-3", "xl:grid-cols-4", "gap-8");
          recipeGallery.classList.add("list-view");
          listViewBtn.classList.add("bg-gray-300", "dark:bg-gray-600");
          gridViewBtn.classList.remove("bg-gray-300", "dark:bg-gray-600");
          imageContainers.forEach(container => {
            container.classList.remove("pb-[75%]");
          });
        } else {
          recipeGallery.classList.remove("list-view");
          recipeGallery.classList.add("grid", "grid-cols-1", "sm:grid-cols-2", "lg:grid-cols-3", "xl:grid-cols-4", "gap-8");
          gridViewBtn.classList.add("bg-gray-300", "dark:bg-gray-600");
          listViewBtn.classList.remove("bg-gray-300", "dark:bg-gray-600");
          imageContainers.forEach(container => {
            container.classList.add("pb-[75%]");
          });
        }
      }
    }

    // Apply saved view on load
    applyView(savedView);

    if (gridViewBtn) {
      gridViewBtn.addEventListener("click", () => {
        applyView("grid");
        localStorage.setItem("recipeViewType", "grid");
      });
    }

    if (listViewBtn) {
      listViewBtn.addEventListener("click", () => {
        applyView("list");
        localStorage.setItem("recipeViewType", "list");
      });
    }
  });
</script>

<!-- Cargar los modales y sus scripts -->
<%- include('partials/footer') %>
