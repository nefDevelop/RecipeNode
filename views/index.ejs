<%- include('partials/header', { title: title || 'Recetas', user: user }) %>

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user, mostViewed: mostViewed }) %>
    <!-- Main Content -->
    <main class="w-full md:w-3/4">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow min-h-[80vh]">
        <% if (content) { %>
        <!-- Controles para escalar comensales -->
        <% if (servings) { %>
        <div
          id="servings-scaler"
          class="flex items-center gap-2 mb-6 p-3 bg-gray-100 dark:bg-gray-700 rounded-lg"
          data-original-servings="<%= servings %>"
        >
          <span class="font-semibold">Comensales:</span>
          <button
            id="servings-minus"
            class="w-8 h-8 rounded-full bg-gray-300 dark:bg-gray-600 font-bold text-lg flex items-center justify-center"
          >
            -
          </button>
          <input
            type="number"
            id="servings-input"
            value="<%= servings %>"
            min="1"
            class="w-16 text-center p-1 border rounded-md dark:bg-gray-800 dark:border-gray-600"
          />
          <button
            id="servings-plus"
            class="w-8 h-8 rounded-full bg-gray-300 dark:bg-gray-600 font-bold text-lg flex items-center justify-center"
          >
            +
          </button>
        </div>
        <% } %> <% if (typeof views !== 'undefined' && views > 0) { %>
        <div class="flex items-center text-gray-500 dark:text-gray-400 mb-4 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
            <path
              fill-rule="evenodd"
              d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.022 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z"
              clip-rule="evenodd"
            />
          </svg>
          <span>Visto <%= views %> veces</span>
        </div>
        <% } %>

        <!-- Estilos específicos para la vista de receta -->
        <link rel="stylesheet" href="/css/kitchen-mode.css" />
        <link rel="stylesheet" href="/css/print.css" media="print" />

        <!-- Si se ha seleccionado una receta, se muestra su contenido -->
        <!-- Contenedor para el Modo Cocina -->
        <div id="recipe-content-wrapper" class="relative">
          <!-- Botones de Acción -->
          <div class="flex flex-wrap justify-end gap-2 mb-4">
            <!-- Modo Cocina -->
            <button
              id="enter-kitchen-mode-btn"
              title="Modo Cocina"
              class="inline-flex items-center justify-center w-10 h-10 border border-transparent rounded-full shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
            >
              <!-- Icono de libro abierto -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                />
              </svg>
            </button>
            <!-- Imprimir -->
            <button
              id="print-recipe-btn"
              class="inline-flex items-center justify-center w-10 h-10 border border-gray-300 dark:border-gray-600 rounded-full shadow-sm text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M5 4v3H4a2 2 0 00-2 2v6a2 2 0 002 2h12a2 2 0 002-2V9a2 2 0 00-2-2h-1V4a2 2 0 00-2-2H7a2 2 0 00-2 2zm8 0H7v3h6V4zm0 8H7v4h6v-4z"
                  clip-rule="evenodd"
                />
              </svg>
            </button>
            <!-- Compartir -->
            <button
              id="share-recipe-btn"
              title="Compartir"
              class="inline-flex items-center justify-center w-10 h-10 border border-gray-300 dark:border-gray-600 rounded-full shadow-sm text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path
                  d="M15 8a3 3 0 10-2.977-2.63l-4.94 2.47a3 3 0 100 4.319l4.94 2.47a3 3 0 10.895-1.789l-4.94-2.47a3.027 3.027 0 000-.74l4.94-2.47C13.456 7.68 14.19 8 15 8z"
                />
              </svg>
            </button>
          </div>

          <!-- Botón para salir (inicialmente oculto por CSS) -->
          <button id="exit-kitchen-mode-btn" title="Salir del Modo Cocina (Esc)">Salir</button>

          <!-- Contenido de la receta -->
          <article class="prose dark:prose-invert lg:prose-xl max-w-none"><%- content %></article>
        </div>
        <% } else { %>
        <!-- Si estamos en la página principal, mostramos la galería -->
        <h1 class="text-3xl font-bold mb-6">Todas las Recetas</h1>
        <div id="recipe-gallery" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          <% if (recipes && recipes.length > 0) { %> <% recipes.forEach(recipe => { %>
          <!-- Contenedor relativo para posicionar el botón de borrado -->
          <div class="relative group">
            <a
              href="/?recipe=<%= encodeURIComponent(recipe.name) %>"
              class="block bg-gray-50 dark:bg-gray-700 rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300"
            >
              <% const displayFields = settings.recipe_card_display_fields || {}; %>
              <% if (displayFields.image) { %>
              <div class="relative pb-[75%] bg-green-100">
                <!-- Ratio de aspecto 4:3 -->
                <% if (recipe.image) { %>
                <img
                  src="<%- recipe.image %>"
                  alt="<%= recipe.name %>"
                  class="absolute h-full w-full object-cover"
                  onerror="this.style.display='none'; this.parentElement.querySelector('.placeholder').style.display='flex';"
                />
                <div
                  class="placeholder absolute h-full w-full bg-green-100 dark:bg-green-900 items-center justify-center"
                  style="display: none"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-12 h-12 text-green-300"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1"
                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                    />
                  </svg>
                </div>
                <% } else { %>
                <div class="absolute h-full w-full bg-green-100 dark:bg-green-900 flex items-center justify-center">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-12 h-12 text-green-300"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1"
                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                    />
                  </svg>
                </div>
                <% } %>
              </div>
              <% } %>
              <div class="p-4">
                <% if (displayFields.name) { %>
                <h3
                  class="font-semibold text-lg text-gray-800 dark:text-gray-200 group-hover:text-green-600 truncate"
                  title="<%= recipe.name %>"
                >
                  <%= recipe.name %>
                </h3>
                <% } %>
                <% if (displayFields.difficulty && recipe.difficulty) { %>
                <p class="text-sm text-gray-500 dark:text-gray-400">Dificultad: <%= recipe.difficulty %></p>
                <% } %>
                <% if (displayFields.cookingTime && recipe.cooking_time) { %>
                <p class="text-sm text-gray-500 dark:text-gray-400">Tiempo: <%= recipe.cooking_time %> min</p>
                <% } %>
                <% if (displayFields.tags && recipe.tags && recipe.tags.length > 0) { %>
                <p class="text-sm text-gray-500 dark:text-gray-400">Etiquetas: <%= recipe.tags.join(', ') %></p>
                <% } %>
                <% if (displayFields.mainIngredient && recipe.main_ingredient) { %>
                <p class="text-sm text-gray-500 dark:text-gray-400">Ingrediente Principal: <%= recipe.main_ingredient %></p>
                <% } %>
                <div class="mt-2 flex items-center text-sm text-gray-500 dark:text-gray-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                    <path
                      fill-rule="evenodd"
                      d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.022 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span><%= recipe.views || 0 %></span>
                </div>
              </div>
            </a>
            <!-- Botón de Borrar (Solo para Admins) -->
            <% if (user && user.role === 'admin') { %>
            <button
              class="delete-recipe-btn absolute top-2 right-2 w-8 h-8 bg-red-600 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
              data-recipe-name="<%= recipe.name %>"
              title="Eliminar receta"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path
                  fill-rule="evenodd"
                  d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z"
                  clip-rule="evenodd"
                />
              </svg>
            </button>
            <% } %>
          </div>
          <% }) %> <% } else { %>
          <!-- Mensaje por si algo falla -->
          <div class="text-center text-gray-500 pt-16 col-span-full">
            <h1 class="text-2xl font-bold">Bienvenido a RecipeNode</h1>
            <p class="mt-2">No hay recetas para mostrar. ¡Añade alguna!</p>
          </div>
          <% } %>
        </div>
        <% } %>
      </div>
    </main>

    <!-- Timer Modal/Overlay -->
    <div id="timer-modal" class="fixed inset-0 bg-black bg-opacity-75 flex items-center justify-center z-[1001] hidden">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-xl text-center relative">
        <h2 id="timer-modal-title" class="text-2xl font-bold mb-4">Temporizador</h2>
        <div id="timer-display" class="text-6xl font-mono mb-6">00:00</div>
        <div class="flex justify-center gap-4">
          <button
            id="timer-start-pause-btn"
            class="px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2"
          >
            Iniciar
          </button>
          <button
            id="timer-reset-btn"
            class="px-6 py-3 bg-yellow-500 text-white rounded-lg hover:bg-yellow-600 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:ring-offset-2"
          >
            Reiniciar
          </button>
          <button
            id="timer-close-btn"
            class="px-6 py-3 bg-gray-300 text-gray-800 rounded-lg hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-200 focus:ring-offset-2"
          >
            Cerrar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.recipeCardDisplaySettings = <%- JSON.stringify(settings.recipe_card_display_fields || {}) %>;

  document.addEventListener("DOMContentLoaded", () => {
    // --- Lógica para Borrar Recetas (Admin) ---
    const deleteButtons = document.querySelectorAll(".delete-recipe-btn");
    deleteButtons.forEach((button) => {
      button.addEventListener("click", async (e) => {
        e.preventDefault(); // Evita que se siga el enlace de la tarjeta
        e.stopPropagation(); // Detiene la propagación del evento

        const recipeName = button.dataset.recipeName;
        if (confirm(`¿Estás seguro de que quieres eliminar la receta "${recipeName}"? Esta acción no se puede deshacer.`)) {
          try {
            const response = await fetch("/api/recipes", {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ title: recipeName }),
            });

            const result = await response.json();
            if (!response.ok) {
              throw new Error(result.error || "Error al eliminar la receta.");
            }

            // Eliminar la tarjeta de la receta del DOM
            button.closest(".relative.group").remove();
            // Opcional: mostrar una notificación de éxito
            alert(result.message);
          } catch (error) {
            alert(`Error: ${error.message}`);
          }
        }
      });
    });

    // --- Print and Share Functionality ---
    const printBtn = document.getElementById("print-recipe-btn");
    if (printBtn) {
      printBtn.addEventListener("click", () => {
        window.print();
      });
    }

    const shareBtn = document.getElementById("share-recipe-btn");
    if (shareBtn) {
      shareBtn.addEventListener("click", async () => {
        const recipeTitle = document.querySelector("#recipe-content-wrapper .prose h1")?.textContent || "Receta de RecipeNode";
        const recipeUrl = window.location.href.split("#")[0]; // URL limpia sin hash

        if (navigator.share) {
          // Usa la API Web Share si está disponible (móviles)
          try {
            await navigator.share({
              title: recipeTitle,
              text: `Echa un vistazo a esta receta: ${recipeTitle}`,
              url: recipeUrl,
            });
          } catch (error) {
            console.error("Error al usar Web Share API:", error);
          }
        } else {
          // Fallback para escritorio: copiar al portapapeles
          try {
            await navigator.clipboard.writeText(recipeUrl);
            const originalText = shareBtn.textContent;
            shareBtn.textContent = "¡Enlace Copiado!";
            setTimeout(() => {
              shareBtn.textContent = originalText;
            }, 2000);
          } catch (err) {
            alert("No se pudo copiar el enlace. Cópialo manualmente desde la barra de direcciones.");
          }
        }
      });
    }

    // --- Ingredient Checkbox Usability ---
    const recipeArticle = document.querySelector(".prose");
    if (recipeArticle) {
      recipeArticle.addEventListener("click", (event) => {
        // Encuentra el elemento de lista (`li`) más cercano al que se hizo clic
        const li = event.target.closest("li");

        // Si el `li` existe y contiene un checkbox...
        if (li && li.querySelector('input[type="checkbox"]')) {
          // ...y el clic no fue directamente en el checkbox (para evitar doble toggle)...
          if (event.target.tagName !== "INPUT") {
            const checkbox = li.querySelector('input[type="checkbox"]');
            checkbox.checked = !checkbox.checked; // ...invierte su estado.
          }
        }
      });
    }
  });
</script>

<!-- Script para el Modo Cocina -->
<script src="/js/kitchen-mode.js"></script>

<!-- Cargar los modales y sus scripts -->
<%- include('partials/footer') %>
