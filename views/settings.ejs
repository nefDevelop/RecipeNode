<%- include('partials/header', { title: title, user: user }) %>

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user }) %>

    <main class="w-full md:w-3/4">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow">
        <h1 class="text-3xl font-bold mb-6">Ajustes</h1>

        <p class="text-gray-600">Aquí podrás gestionar la configuración de tu cuenta.</p>

        <% if (user && user.role === 'admin') { %> <% } %>
      </div>
    </main>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const deleteForm = document.getElementById("delete-recipe-form");
    if (deleteForm) {
      deleteForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const title = e.target.title.value;
        if (!title) {
          alert("Por favor, selecciona una receta para eliminar.");
          return;
        }
        if (confirm(`¿Estás seguro de que quieres eliminar la receta "${title}"? Esta acción no se puede deshacer.`)) {
          try {
            const res = await fetch(`/api/recipes`, {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ title }),
            });
            if (res.ok) {
              alert("Receta eliminada correctamente.");
              window.location.reload();
            } else {
              const data = await res.json();
              alert(`Error al eliminar la receta: ${data.error || "Error desconocido"}`);
            }
          } catch (err) {
            alert("Error de red al intentar eliminar la receta.");
          }
        }
      });
    }
  });
</script>

<%- include('partials/footer') %>
