<%- include('partials/header', { title: title, user: user }) %>

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user }) %>

    <main class="w-full md:w-3/4">
      <div class="bg-white p-6 rounded-lg shadow">
        <h1 class="text-3xl font-bold mb-6">Ajustes</h1>

        <p class="text-gray-600">Aquí podrás gestionar la configuración de tu cuenta.</p>

        <% if (user && user.role === 'admin') { %>
        <div class="mt-8 pt-8 border-t">
          <h2 class="text-xl font-semibold mb-4">Administración</h2>
          <form id="delete-recipe-form">
            <label for="recipe-to-delete" class="block text-sm font-medium text-gray-700 mb-2">Eliminar una receta</label>
            <div class="flex rounded-md shadow-sm">
              <select
                id="recipe-to-delete"
                name="title"
                class="flex-1 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300 focus:ring-red-500 focus:border-red-500"
              >
                <option value="">-- Selecciona una receta para eliminar --</option>
                <% recipeTitles.forEach(function(title) { %>
                <option value="<%= title %>"><%= title %></option>
                <% }); %>
              </select>
              <button
                type="submit"
                class="px-4 py-2 rounded-r-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
              >
                Eliminar
              </button>
            </div>
          </form>
        </div>
        <% } %>
      </div>
    </main>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const deleteForm = document.getElementById("delete-recipe-form");
    if (deleteForm) {
      deleteForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const title = e.target.title.value;
        if (!title) {
          alert("Por favor, selecciona una receta para eliminar.");
          return;
        }
        if (confirm(`¿Estás seguro de que quieres eliminar la receta "${title}"? Esta acción no se puede deshacer.`)) {
          try {
            const res = await fetch(`/api/recipes`, {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ title }),
            });
            if (res.ok) {
              alert("Receta eliminada correctamente.");
              window.location.reload();
            } else {
              const data = await res.json();
              alert(`Error al eliminar la receta: ${data.error || "Error desconocido"}`);
            }
          } catch (err) {
            alert("Error de red al intentar eliminar la receta.");
          }
        }
      });
    }
  });
</script>

<%- include('partials/footer') %>
