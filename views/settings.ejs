<%- include('partials/header', { title: title, user: user }) %>

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user }) %>

    <main class="w-full md:w-3/4">
      <div class="bg-white p-6 rounded-lg shadow">
        <h1 class="text-3xl font-bold mb-6">Ajustes</h1>
        <form action="/settings" method="POST">
          <h2 class="text-xl font-semibold mb-4">Conversión de Unidades</h2>
          <p class="text-gray-600 mb-6">
            Define cuántas unidades base (gramos o mililitros) equivalen a una unidad mayor (kg o litro). Esto se usa para agregar
            ingredientes en la lista de la compra.
          </p>

          <div class="space-y-4">
            <div>
              <label for="kg-to-g" class="block text-sm font-medium text-gray-700">1 kilogramo (kg) equivale a:</label>
              <div class="mt-1 flex rounded-md shadow-sm">
                <input
                  type="number"
                  name="kg-to-g"
                  id="kg-to-g"
                  class="flex-1 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300"
                  value="<%= settings['kg-to-g'] || 1000 %>"
                />
                <span class="inline-flex items-center px-3 rounded-r-md border border-l-0 border-gray-300 bg-gray-50 text-gray-500 text-sm"
                  >gramos (g)</span
                >
              </div>
            </div>

            <div>
              <label for="l-to-ml" class="block text-sm font-medium text-gray-700">1 litro (l) equivale a:</label>
              <div class="mt-1 flex rounded-md shadow-sm">
                <input
                  type="number"
                  name="l-to-ml"
                  id="l-to-ml"
                  class="flex-1 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300"
                  value="<%= settings['l-to-ml'] || 1000 %>"
                />
                <span class="inline-flex items-center px-3 rounded-r-md border border-l-0 border-gray-300 bg-gray-50 text-gray-500 text-sm"
                  >mililitros (ml)</span
                >
              </div>
            </div>
          </div>

          <div class="mt-8">
            <button
              type="submit"
              class="px-6 py-2 rounded text-white inline-block shadow-lg bg-green-500 hover:bg-green-600 focus:bg-green-700"
            >
              Guardar Ajustes
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>
</div>

<%- include('partials/footer') %>
