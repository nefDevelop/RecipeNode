<%- include('partials/header', { title: 'Ajustes' }) %>

<div class="bg-white p-6 rounded-lg shadow max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-6 border-b pb-4">Ajustes de la Aplicación</h1>

  <form action="/settings" method="POST">
    <h2 class="text-lg font-semibold text-gray-700 mb-4">Conversión de Unidades</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="kg-to-g" class="block text-sm font-medium text-gray-700">Gramos en 1 Kilogramo</label>
        <input
          type="number"
          step="any"
          name="kg-to-g"
          id="kg-to-g"
          value="<%= settings['kg-to-g'] || 1000 %>"
          class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
        />
      </div>
      <div>
        <label for="l-to-ml" class="block text-sm font-medium text-gray-700">Mililitros en 1 Litro</label>
        <input
          type="number"
          step="any"
          name="l-to-ml"
          id="l-to-ml"
          value="<%= settings['l-to-ml'] || 1000 %>"
          class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
        />
      </div>
      <div>
        <label for="cup-to-ml" class="block text-sm font-medium text-gray-700">Mililitros en 1 Taza (cup)</label>
        <input
          type="number"
          step="any"
          name="cup-to-ml"
          id="cup-to-ml"
          value="<%= settings['cup-to-ml'] || 240 %>"
          class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
        />
      </div>
      <div>
        <label for="tbsp-to-ml" class="block text-sm font-medium text-gray-700">Mililitros en 1 Cucharada (tbsp)</label>
        <input
          type="number"
          step="any"
          name="tbsp-to-ml"
          id="tbsp-to-ml"
          value="<%= settings['tbsp-to-ml'] || 15 %>"
          class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
        />
      </div>
      <div>
        <label for="tsp-to-ml" class="block text-sm font-normal text-gray-700">Mililitros en 1 Cucharadita (tsp)</label>
        <input
          type="number"
          step="any"
          name="tsp-to-ml"
          id="tsp-to-ml"
          value="<%= settings['tsp-to-ml'] || 5 %>"
          class="mt-1 block w-full px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm"
        />
      </div>
    </div>

    <div class="mt-8 text-right">
      <button type="submit" class="px-6 py-2 rounded text-white inline-block shadow-lg bg-green-500 hover:bg-green-600 focus:bg-green-700">
        Guardar Cambios
      </button>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
