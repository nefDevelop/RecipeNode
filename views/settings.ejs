<%- include('partials/header', { title: title, user: user }) %>

<div class="container mx-auto p-4">
  <div class="md:flex md:gap-6">
    <!-- Overlay para el menú lateral, z-30 para que esté debajo del header (z-50) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black bg-opacity-50 z-30 hidden md:hidden"></div>

    <%- include('partials/sidebar', { recipeTitles: recipeTitles, user: user }) %>

    <main class="w-full md:w-3/4">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow">
        <h1 class="text-3xl font-bold mb-6">Ajustes</h1>

        <p class="text-gray-600">Aquí podrás gestionar la configuración de tu cuenta.</p>

        <% if (user && user.role === 'admin') { %> <% } %>

        <h2 class="text-2xl font-bold mt-8 mb-4">Gestionar Pestañas de la Lista de Compra</h2>
        <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg shadow-inner mb-6">
          <form id="create-tab-form" class="flex gap-2">
            <input
              type="text"
              id="new-tab-name"
              placeholder="Nombre de la nueva pestaña"
              class="flex-grow p-2 border rounded-md dark:bg-gray-800 dark:border-gray-600"
              required
            />
            <button type="submit" class="px-4 py-2 bg-blue-500 text-white font-semibold rounded-md shadow-sm hover:bg-blue-600">
              Crear Pestaña
            </button>
          </form>
          <div id="tabs-list" class="mt-4">
            <!-- Las pestañas existentes se cargarán aquí -->
          </div>
        </div>

        <h2 class="text-2xl font-bold mt-8 mb-4">Configuración de Carpeta de Imágenes</h2>
        <form action="/settings/image-folder" method="POST" class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg shadow-inner">
          <div class="mb-4">
            <label for="image_folder" class="block text-sm font-medium text-gray-700 dark:text-gray-200">Ruta a la carpeta de imágenes</label>
            <input type="text" id="image_folder" name="image_folder" value="<%= settings.image_folder %>" class="mt-1 block w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500 sm:text-sm">
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">La ruta a la carpeta que contiene las imágenes de las recetas. Por defecto es `_resources`.</p>
          </div>
          <button type="submit" class="px-4 py-2 bg-green-600 text-white font-semibold rounded-md shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">Guardar Carpeta de Imágenes</button>
        </form>

        <h2 class="text-2xl font-bold mt-8 mb-4">Configuración de Tarjetas de Receta</h2>
        <form action="/settings" method="POST" class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg shadow-inner">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <% const displayFields = settings.recipe_card_display_fields || {}; %>
            <% const fields = [
              { id: 'image', label: 'Imagen', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>' },
              { id: 'name', label: 'Nombre de la Receta', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" /></svg>' },
              { id: 'difficulty', label: 'Dificultad', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>' },
              { id: 'cookingTime', label: 'Tiempo de Cocción', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>' },
              { id: 'tags', label: 'Etiquetas', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>' },
              { id: 'mainIngredient', label: 'Ingrediente Principal', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>' },
              { id: 'cuisineType', label: 'Tipo de Cocina', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.54 15H17a2 2 0 0 0-2 2v4.54"/><path d="M7 3.34V5a3 3 0 0 0 3 3a2 2 0 0 1 2 2c0 1.1.9 2 2 2a2 2 0 0 0 2-2c0-1.1.9-2 2-2h3.17"/><path d="M11 21.95V18a2 2 0 0 0-2-2a2 2 0 0 1-2-2v-1a2 2 0 0 0-2-2H2.05"/><circle cx="12" cy="12" r="10"/></svg>' },
              { id: 'views', label: 'Vistas', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>' },
              { id: 'description', label: 'Descripción', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" /></svg>' },
              { id: 'mealType', label: 'Tipo de Comida', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.701 2.701 0 00-1.5-.454M9 6v2m3-2v2m3-2v2M9 3h.01M12 3h.01M15 3h.01M21 21v-7a2 2 0 00-2-2H5a2 2 0 00-2 2v7h18zm-3-9v-2a2 2 0 00-2-2H8a2 2 0 00-2 2v2h12z" /></svg>' },
              { id: 'rating', label: 'Puntuación', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>' },
              { id: 'equipment', label: 'Equipamiento', icon: '<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>' }
            ]; %>

            <% fields.forEach(field => { %>
              <label class="flex items-center justify-between p-4 bg-white dark:bg-gray-800 rounded-lg shadow cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <div class="flex items-center gap-3">
                  <%- field.icon %>
                  <span class="font-medium text-gray-700 dark:text-gray-200"><%= field.label %></span>
                </div>
                <input
                  type="checkbox"
                  name="recipe_card_display_fields[<%= field.id %>]"
                  value="true"
                  class="h-5 w-5 text-green-600 rounded focus:ring-green-500 border-gray-300 dark:border-gray-600 dark:bg-gray-700"
                  <%= displayFields[field.id] ? 'checked' : '' %>
                />
              </label>
            <% }); %>
          </div>
          <button
            type="submit"
            class="mt-6 px-4 py-2 bg-green-600 text-white font-semibold rounded-md shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
          >
            Guardar Configuración de Tarjetas
          </button>
        </form>
      </div>
    </main>
  </div>
  <%- include('partials/footer') %>
</div>
<script src="/js/settings-tabs.js"></script>
